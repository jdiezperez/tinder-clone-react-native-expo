// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  bio       String?
  age       Int?
  gender    String?
  photos    Photo[]
  likes     Like[]   @relation("LikesFrom")
  likedBy   Like[]   @relation("LikesTo")
  matchesA  Match[]  @relation("UserMatchesA")
  matchesB  Match[]  @relation("UserMatchesB")
  createdAt DateTime @default(now())

  swipesA   Swipe[]  @relation("UserSwipesA")
  swipesB   Swipe[]  @relation("UserSwipesB")
}

model Photo {
  id     Int    @id @default(autoincrement())
  url    String
  isPrimary Boolean   @default(false)
  user   User   @relation(fields: [userId], references: [id])
  userId Int
  createdAt DateTime  @default(now())
}

model Like {
  id     Int  @id @default(autoincrement())
  from   User @relation("LikesFrom", fields: [fromId], references: [id])
  fromId Int
  to     User @relation("LikesTo", fields: [toId], references: [id])
  toId   Int
  @@unique([fromId, toId])
}

model Match {
  id        Int      @id @default(autoincrement())
  userA     User     @relation("UserMatchesA", fields: [userAId], references: [id])
  userAId   Int
  userB     User     @relation("UserMatchesB", fields: [userBId], references: [id])
  userBId   Int
  createdAt DateTime @default(now())
  messages  Message[]
  @@unique([userAId, userBId])
}

model Swipe {
  id        Int      @id @default(autoincrement())
  userA     User     @relation("UserSwipesA", fields: [userAId], references: [id])
  userAId   Int
  userB     User     @relation("UserSwipesB", fields: [userBId], references: [id])
  userBId   Int
  liked     Boolean
  createdAt DateTime @default(now())
  @@unique([userAId, userBId])
}

model Message {
  id        Int      @id @default(autoincrement())
  match     Match    @relation(fields: [matchId], references: [id])
  matchId   Int
  senderId  Int
  content   String
  createdAt DateTime @default(now())
}